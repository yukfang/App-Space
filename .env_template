# Legacy Prisma / App & ApiCredential (optional)
OPENAPI_TTS_DB_URL=

# API OAuth credentials DB (tts_*, future snap_*, google_*, …)
API_AUTH_DB=

# Public URL of this deployment (no trailing slash).
# Overrides tts_app.redirect_domain for /success and /failure; also used for OAuth callback if TTS_OAUTH_REDIRECT_URI is unset.
APP_PUBLIC_URL=https://your-production-host.example.com

# Must match redirect URI registered in TikTok Partner Center
TTS_OAUTH_REDIRECT_URI=
